<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.engg1420.ui.UserManagementController">
   <children>
      <Label layoutX="168.0" layoutY="25.0" prefHeight="35.0" prefWidth="266.0" text="User Management Registry" textAlignment="CENTER">
         <font>
            <Font name="Times New Roman" size="24.0" />
         </font>
      </Label>
      <TableView layoutX="55.0" layoutY="68.0" prefHeight="200.0" prefWidth="487.0" fx:id="tableView">
        <columns>
            <TableColumn prefWidth="75.0" text="Name" fx:id="nameColumn"/>
            <TableColumn prefWidth="75.0" text="User ID" fx:id="idColumn"/>
            <TableColumn prefWidth="75.0" text="User Type" fx:id="userTypeColumn"/>
            <TableColumn prefWidth="75.0" text="User Name" fx:id="userNameColumn"/>
            <TableColumn prefWidth="75.0" text="Password" fx:id="passwordColumn"/>
            <TableColumn prefWidth="112.0" text="Booked Event(s)" fx:id="eventsBookedColumn"/>

        </columns>
      </TableView>
   </children>
</AnchorPane>
