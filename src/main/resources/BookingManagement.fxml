      <Button fx:id="login" layoutX="537.0" layoutY="368.0" mnemonicParsing="false" onAction="#handleLogin" style="-fx-background-color: #FFCCCB;" text="Login" />
      <Button fx:id="book" layoutX="486.0" layoutY="368.0" mnemonicParsing="false" onAction="#handleBook" style="-fx-background-color: #FFCCCB;" text="Book" />
