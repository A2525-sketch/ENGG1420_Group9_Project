<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.engg1420.ui.MainController">
   <children>
      <AnchorPane layoutX="4.0" layoutY="3.0" prefHeight="390.0" prefWidth="594.0" style="-fx-background-color: #353935;">
